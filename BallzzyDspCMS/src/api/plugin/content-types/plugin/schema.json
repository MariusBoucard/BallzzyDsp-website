{
  "kind": "collectionType",
  "collectionName": "plugins",
  "info": {
    "singularName": "plugin",
    "pluralName": "plugins",
    "displayName": "plugin"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "editor": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "name": {
      "type": "string"
    },
    "releaseDate": {
      "type": "date"
    },
    "version": {
      "type": "string"
    },
    "githubRepo": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "os_supporteds": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::os-supported.os-supported"
    },
    "formats": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::format.format"
    },
    "downloadLinksingle": {
      "type": "string"
    },
    "download_links": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::download-link.download-link"
    }
  }
}
